# Copia in .env e compila con i tuoi valori
DATABASE_URL=postgresql://meteo_user:password@localhost:5432/meteo_ai
GEMINI_API_KEY=your_gemini_key_here
ADMIN_API_TOKEN=change_me_with_a_long_random_secret
APP_ENV=development
FRONTEND_ORIGIN=https://leprevisioni.netlify.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CHAT_REQUESTS_PER_MINUTE=15
CHAT_REQUESTS_PER_DAY=300
MAX_MODEL_STORE_RECORDS=5
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
SUPPORTER_EMAIL_ENCRYPTION_KEY=replace_me_with_fernet_key
SUPPORTER_EMAIL_HASH_KEY=replace_me_with_a_long_random_secret

# URL pubblico del backend (usato dal frontend Netlify)
BACKEND_URL=https://tuo-dominio.com

# Porta del server (default 8000)
PORT=8000
